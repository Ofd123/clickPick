<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SchoolProj">
        <activity
            android:name=".search_results_screen"
            android:exported="false" />
        <activity
            android:name=".screens.search_screen"
            android:exported="false" />
        <activity
            android:name=".screens.main_screen"
            android:exported="true" > <!-- tells the os to read the content of that file -->
            <!-- will count the file as the main activity -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".screens.saved_items_screen"
            android:exported="false" />
        <activity
            android:name=".screens.search_history_screen"
            android:exported="false" />
        <activity
            android:name=".screens.signUp_screen"
            android:exported="false" />
        <activity
            android:name=".screens.login_screen"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="false">
        </activity>
    </application>

</manifest>